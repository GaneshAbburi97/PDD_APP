<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration
  Allows cleartext (HTTP) traffic to the local development backend running on:
    - 10.0.2.2       (Android emulator → host machine's localhost)
    - 192.168.x.x    (physical device on the same LAN)
    - localhost / 127.0.0.1 (loopback; used by Robolectric / unit tests)

  All other traffic continues to require TLS (cleartext is denied by default).
-->
<network-security-config>

    <!-- ── Local development hosts (HTTP allowed) ── -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator → host machine -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Local network (adjust subnet if needed) -->
        <domain includeSubdomains="false">192.168.1.100</domain>
        <!-- Loopback -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <!-- ── Default: require TLS for all other traffic ── -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>

# ──────────────────────────────────────────────────────────────────────────────
# PDD Medical AI Backend – Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values before running the server.

# Application
APP_NAME="PDD Medical AI Platform"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=*

# ──────────────────────────────────────────────────────────────────────────────
# Firebase / Google Cloud
# ──────────────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=medical-processor-prod
FIREBASE_STORAGE_BUCKET=medical-processor-prod.appspot.com

# Option A: Path to service-account JSON file (recommended for Docker/VM)
GOOGLE_APPLICATION_CREDENTIALS=/secrets/service-account.json

# Option B: Inline base64-encoded service-account JSON (for env-var-only deployments)
# FIREBASE_SERVICE_ACCOUNT_JSON=<base64-encoded JSON string>

# ──────────────────────────────────────────────────────────────────────────────
# AI / Model
# ──────────────────────────────────────────────────────────────────────────────
# Device: auto | cpu | cuda | cuda:0
MODEL_DEVICE=auto
DEFAULT_MODEL_ARCH=unet
MODEL_CHECKPOINT_DIR=/app/checkpoints

# ──────────────────────────────────────────────────────────────────────────────
# Worker
# ──────────────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL_SECONDS=2.0

# ──────────────────────────────────────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
MAX_FILE_SIZE_MB=500

# ──────────────────────────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# json | text
LOG_FORMAT=json

# ──────────────────────────────────────────────────────────────────────────────
# Temp storage
# ──────────────────────────────────────────────────────────────────────────────
TEMP_DIR=/tmp/pdd_processing

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Medical AI Backend"
APP_VERSION="1.0.0"
DEBUG=true

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost","http://10.0.2.2","http://127.0.0.1"]

# ── Firebase ──────────────────────────────────────────────────────────────────
# Path to your downloaded service-account JSON key file
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
# Your Firebase Storage bucket name (e.g. myproject.appspot.com)
FIREBASE_STORAGE_BUCKET=medical-processor-prod.appspot.com

# ── AI Model ──────────────────────────────────────────────────────────────────
MODEL_CHECKPOINT_PATH=models/ian_unet.pth
MODEL_INPUT_SIZE=512
# "cpu" or "cuda" — use "cpu" for laptop/research execution
INFERENCE_DEVICE=cpu
INFERENCE_TIMEOUT_SECONDS=120

# ── Storage ───────────────────────────────────────────────────────────────────
TEMP_DIR=/tmp/medical_processor
